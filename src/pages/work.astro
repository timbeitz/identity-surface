---
import BaseLayout from "../layouts/BaseLayout.astro";
import { caseStudies } from "../data/work";
---

<BaseLayout title="Work — timbeitz.com" description="Selected case studies — product, brand, and research work.">
  <section class="work-intro">
    <div class="eyebrow">Work</div>
    <h1 class="section-title">Selected case studies.</h1>
  </section>

  <section class="case-index" aria-label="Case studies">
    {caseStudies.map((c) => (
      <a class="case-link" href={`/work/${c.slug}`}>
        <div class="case-link-head">
          <span class="case-link-title">{c.title}</span>
          <span class="case-link-year mono">{c.year}</span>
        </div>
        <ul class="tags">
          {c.tags.map((t) => <li class="tag">{t}</li>)}
        </ul>
      </a>
    ))}
  </section>

  <style>
    .work-intro {
      display: grid;
      gap: 8px;
    }

    .case-index {
      margin-top: 32px;
      border-top: 1px solid var(--line);
    }

    .case-link {
      display: grid;
      gap: 12px;
      padding: 22px 0;
      border-bottom: 1px solid var(--line);
    }

    .case-link:hover {
      text-decoration: none;
    }

    .case-link-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 16px;
    }

    .case-link-title {
      font-size: var(--fs-lede);
      font-weight: 500;
    }

    .case-link:hover .case-link-title {
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    /* Date — distinct info type from tags: mono, no chrome */
    .case-link-year {
      font-size: var(--fs-label);
      color: var(--muted);
      white-space: nowrap;
    }

    /* Tags — atomic category pills */
    .tags {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .tag {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--muted);
      border: 1px solid var(--line);
      border-radius: 100px;
      padding: 3px 10px;
    }
  </style>
</BaseLayout>
