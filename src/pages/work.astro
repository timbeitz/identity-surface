---
import BaseLayout from "../layouts/BaseLayout.astro";
import { caseStudies } from "../data/work";
---

<BaseLayout title="Work — Tim Beitz" description="Selected case studies — product, brand, and research work.">
  <section class="work-intro">
    <div class="eyebrow">Work</div>
    <h1 class="section-title">Selected case studies.</h1>
    <p class="section-lede">
      A few projects where the brief was one thing and the work turned out to be
      another — product, brand, and research, mostly for teams who needed all three.
    </p>
  </section>

  <section class="case-index" aria-label="Case studies">
    {caseStudies.map((c) => (
      <a class="case-link" href={`/work/${c.slug}`}>
        <div class="case-link-main">
          <span class="case-link-title">{c.title}</span>
          <span class="case-link-framing">{c.framing}</span>
        </div>
        <span class="case-link-meta mono">{c.summary}</span>
        <span class="case-link-arrow" aria-hidden="true">→</span>
      </a>
    ))}
  </section>

  <style>
    .work-intro {
      display: grid;
      gap: 10px;
    }

    .case-index {
      margin-top: 36px;
      border-top: 1px solid var(--line);
    }

    .case-link {
      display: grid;
      grid-template-columns: 1fr auto;
      grid-template-areas:
        "main arrow"
        "meta arrow";
      gap: 6px 20px;
      align-items: start;
      padding: 22px 0;
      border-bottom: 1px solid var(--line);
    }

    .case-link:hover {
      text-decoration: none;
    }

    .case-link-main {
      grid-area: main;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .case-link-title {
      font-size: 1.25rem;
      font-weight: 500;
    }

    .case-link:hover .case-link-title {
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .case-link-framing {
      color: var(--muted);
      max-width: 56ch;
    }

    .case-link-meta {
      grid-area: meta;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--muted);
    }

    .case-link-arrow {
      grid-area: arrow;
      align-self: center;
      color: var(--muted);
      transition: transform 0.12s ease;
    }

    .case-link:hover .case-link-arrow {
      transform: translateX(4px);
      color: var(--fg);
    }

    @media (max-width: 600px) {
      .case-link {
        grid-template-columns: 1fr;
        grid-template-areas:
          "main"
          "meta";
      }

      .case-link-arrow {
        display: none;
      }
    }
  </style>
</BaseLayout>
