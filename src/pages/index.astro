---
import BaseLayout from "../layouts/BaseLayout.astro";
import { resume } from "../data/resume";

const bioFile = await import("../content/bio.md");
const Bio = bioFile.default;
const { tagline } = bioFile.frontmatter;

// Roles — distilled from the public voice spec (umbrella: creative technologist).
// PLACEHOLDER ORDER — confirm with Tim.
const roles = ["Creative Technologist", "Creative Director", "Systems Architect"];
---

<BaseLayout title={resume.name} description={`${resume.title} – ${resume.location}`}>
  <!-- Type-as-hero (New Utilitarian) -->
  <section class="hero">
    <div class="hero-bottom">
      <div class="hero-identity">
        <h1 class="hero-name">Tim<br />Beitz</h1>
        <div class="hero-roles">
          {roles.map((r) => <span class="hero-role">/ {r}</span>)}
        </div>
      </div>
      <div class="hero-meta">
        <span class="mono meta-coords">39.9526°N · 75.1652°W</span>
        <time id="clock" class="mono meta-clock">--:--:--</time>
        <span class="mono meta-copy">© 2026 Tim Beitz</span>
      </div>
    </div>
  </section>

  <section class="bio">
    <div class="bio-content"><Bio /></div>
    <p class="tagline">{tagline}</p>
  </section>

  <section class="experience">
    <div class="eyebrow exp-label">Experience</div>
    <table>
      <tbody>
        {resume.experience.map((job) => (
          <tr>
            <td class="role">{job.role}</td>
            <td class="hide-mobile type mono">{job.type}</td>
            <td class="company">{job.company}</td>
            <td class="mono years">{job.years}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="details">
    <div class="detail-row">
      <div class="detail-label mono">Skills</div>
      <div class="detail-content">{resume.skills.join(", ")}</div>
    </div>
    <div class="detail-row">
      <div class="detail-label mono">Education</div>
      <div class="detail-content">{resume.education.degree}, {resume.education.school}</div>
    </div>
    <div class="detail-row">
      <div class="detail-label mono">Contact</div>
      <div class="detail-content contact-links">
        <a href={`mailto:${resume.contact.email}`}>{resume.contact.email}</a>
        <a href={`https://${resume.contact.linkedin}`} target="_blank" rel="noopener">{resume.contact.linkedin}</a>
      </div>
    </div>
  </section>

  <style>
    /* ── Hero ───────────────────────────────────────── */
    .hero {
      min-height: 62vh;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding-bottom: var(--sp-l);
    }

    .hero-bottom {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: var(--sp-xl);
      flex-wrap: wrap;
    }

    .hero-name {
      font-size: var(--fs-hero);
      font-weight: 300;
      letter-spacing: -0.035em;
      line-height: 0.9;
      margin: 0;
      opacity: 0;
      transform: translateY(24px);
      animation: rise 0.9s var(--ease-out) 0.05s forwards;
    }

    .hero-identity {
      display: flex;
      align-items: flex-end;
      gap: var(--sp-m);
    }

    .hero-roles {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
      padding-bottom: 0.8rem;
      opacity: 0;
      animation: fade 0.8s ease 0.5s forwards;
    }

    .hero-role {
      font-family: var(--mono);
      font-size: var(--fs-label);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--fg-mid);
    }

    .hero-meta {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 0.4rem;
      padding-bottom: 0.4rem;
      opacity: 0;
      animation: fade 0.8s ease 0.7s forwards;
    }

    .meta-coords,
    .meta-copy {
      font-size: var(--fs-meta);
      color: var(--muted);
      letter-spacing: 0.06em;
    }

    .meta-clock {
      font-size: 1.1rem;
      color: var(--fg-mid);
      letter-spacing: 0.04em;
      font-variant-numeric: tabular-nums;
    }

    @keyframes rise {
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fade {
      to { opacity: 1; }
    }

    /* ── Bio ────────────────────────────────────────── */
    .bio {
      max-width: 52ch;
      border-top: 1px solid var(--line);
      padding-top: var(--sp-l);
    }

    .bio-content :global(p) {
      margin: 0 0 12px;
      color: var(--fg-mid);
      font-size: var(--fs-lede);
      line-height: 1.55;
      font-weight: 300;
    }

    .tagline {
      color: var(--fg) !important;
      font-weight: 400;
      font-size: var(--fs-body);
    }

    /* ── Experience ─────────────────────────────────── */
    .exp-label {
      margin-bottom: 12px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    td {
      text-align: left;
      padding: 14px 0;
      border-bottom: 1px solid var(--line);
      font-size: var(--fs-body);
    }

    tbody tr:last-child td {
      border-bottom: none;
    }

    .company {
      color: var(--fg);
    }

    .role {
      color: var(--fg);
    }

    .type {
      color: var(--muted);
      font-size: var(--fs-label);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .years {
      text-align: right;
      color: var(--muted);
      font-size: var(--fs-meta);
    }

    /* ── Details ────────────────────────────────────── */
    .details {
      display: grid;
      gap: 16px;
    }

    .detail-row {
      display: grid;
      grid-template-columns: 120px 1fr;
      gap: 16px;
      font-size: var(--fs-body);
    }

    .detail-label {
      font-size: var(--fs-label);
      text-transform: uppercase;
      letter-spacing: var(--tracking-label);
      color: var(--muted);
      padding-top: 3px;
    }

    .detail-content {
      color: var(--fg-mid);
    }

    .contact-links {
      display: flex;
      gap: 20px;
    }

    .contact-links a {
      font-family: var(--mono);
      font-size: var(--fs-meta);
    }

    @media (max-width: 600px) {
      .hide-mobile { display: none; }
      .hero-identity { flex-direction: column; align-items: flex-start; gap: 1.6rem; }
      .hero-bottom { flex-direction: column; align-items: flex-start; gap: var(--sp-m); }
      .hero-meta { align-items: flex-start; }
      .detail-row { grid-template-columns: 1fr; gap: 4px; }
      .contact-links { flex-direction: column; gap: 8px; }
    }
  </style>

  <script>
    const clockEl = document.getElementById("clock");
    if (clockEl) {
      const tick = () => {
        clockEl.textContent = new Intl.DateTimeFormat("en-US", {
          timeZone: "America/New_York",
          hour: "2-digit",
          minute: "2-digit",
          second: "2-digit",
          hour12: false,
        }).format(new Date());
      };
      tick();
      setInterval(tick, 1000);
    }
  </script>
</BaseLayout>
