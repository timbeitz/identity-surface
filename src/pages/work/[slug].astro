---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { caseStudies } from "../../data/work";

export function getStaticPaths() {
  return caseStudies.map((c) => ({
    params: { slug: c.slug },
    props: { caseStudy: c },
  }));
}

const { caseStudy } = Astro.props;
---

<BaseLayout
  title={`${caseStudy.title} — Work — timbeitz.com`}
  description={caseStudy.framing}
>
  <article class="case">
    <a class="case-back" href="/work">← Work</a>

    <header class="case-header">
      <h1 class="case-title">{caseStudy.title}</h1>
      <p class="case-framing">{caseStudy.framing}</p>
      <div class="case-meta">
        <ul class="tags">
          {caseStudy.tags.map((t) => <li class="tag">{t}</li>)}
        </ul>
        <span class="case-year mono">{caseStudy.year}</span>
      </div>
    </header>

    <hr class="case-rule" />

    <div class="case-body">
      <p class="case-lede">{caseStudy.lede}</p>

      {caseStudy.sections.map((section) => (
        <section class="case-section">
          <h2 class="case-label">{section.label}</h2>
          {section.body.map((p) => <p class="case-p">{p}</p>)}
        </section>
      ))}

      <section class="case-scope">
        <h2 class="case-label">Scope</h2>
        <dl class="scope-grid">
          {caseStudy.scope.map((row) => (
            <div class="scope-row">
              <dt>{row.label}</dt>
              <dd>{row.value}</dd>
            </div>
          ))}
        </dl>
      </section>
    </div>
  </article>

  <style>
    .case {
      max-width: 680px;
    }

    .case-back {
      display: inline-block;
      font-size: var(--fs-label);
      text-transform: uppercase;
      letter-spacing: var(--tracking-label);
      color: var(--muted);
    }

    .case-back:hover {
      color: var(--fg);
      text-decoration: none;
    }

    /* ---- Header: title → short description → tags ---- */
    .case-header {
      margin-top: 28px;
    }

    .case-title {
      font-size: var(--fs-title);
      line-height: 1.05;
      letter-spacing: -0.01em;
      font-weight: 500;
      margin: 0;
    }

    .case-framing {
      font-size: var(--fs-lede);
      line-height: 1.4;
      font-weight: 500;
      color: var(--fg);
      max-width: 44ch;
      margin: 14px 0 0;
    }

    .case-meta {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 10px 16px;
      margin-top: 18px;
    }

    .tags {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .tag {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--muted);
      border: 1px solid var(--line);
      border-radius: 100px;
      padding: 3px 10px;
    }

    .case-year {
      font-size: var(--fs-label);
      color: var(--muted);
    }

    /* ---- Rule separating header from body ---- */
    .case-rule {
      border: 0;
      border-top: 1px solid var(--line);
      margin: 28px 0 0;
    }

    /* ---- Body ---- */
    .case-body {
      margin-top: 28px;
    }

    .case-lede {
      font-size: var(--fs-lede);
      line-height: 1.6;
      color: var(--muted);
      max-width: 64ch;
      margin: 0;
    }

    .case-section {
      margin-top: 40px;
    }

    .case-label {
      font-size: var(--fs-label);
      text-transform: uppercase;
      letter-spacing: 0.22em;
      color: var(--muted);
      font-weight: 500;
      margin: 0 0 14px;
    }

    .case-p {
      max-width: 66ch;
      margin: 0 0 16px;
      font-size: var(--fs-body);
      line-height: 1.7;
      color: var(--fg);
    }

    .case-p:last-child {
      margin-bottom: 0;
    }

    .case-scope {
      margin-top: 48px;
      border-top: 1px solid var(--line);
      padding-top: 28px;
    }

    .scope-grid {
      margin: 0;
      max-width: 64ch;
    }

    .scope-row {
      display: grid;
      grid-template-columns: 150px 1fr;
      gap: 24px;
      padding: 11px 0;
      border-bottom: 1px solid var(--line);
    }

    .scope-row:last-child {
      border-bottom: none;
    }

    .scope-row dt {
      font-family: var(--mono);
      font-size: var(--fs-label);
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--muted);
      padding-top: 2px;
    }

    .scope-row dd {
      margin: 0;
      font-size: var(--fs-body);
      line-height: 1.5;
    }

    @media (max-width: 600px) {
      .scope-row {
        grid-template-columns: 1fr;
        gap: 4px;
      }
    }
  </style>
</BaseLayout>
