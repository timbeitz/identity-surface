---
const {
  title = "timbeitz.com",
  description = "Tim Beitz — product, brand, and research work.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      /* ──────────────────────────────────────────────────────────────
         New Utilitarian foundation — tokens carried forward from
         ventures/self/acs250/design-draft-v1.html, grounded in
         entities/product/website-poc/DESIGN-REFERENCE.md.
         Warm-grey monochrome, dark default, Helvetica Neue + SF Mono.
         Token NAMES are the stable interface so every page inherits.
         ────────────────────────────────────────────────────────────── */
      :root {
        color-scheme: dark light;

        /* warm-grey ramp — DARK default */
        --bg: #0a0a09;
        --bg-0: #0a0a09;
        --bg-1: #131310;
        --bg-2: #1c1c18;
        --fg: #edeae3;
        --fg-mid: #c8c5be;
        --muted: #78786f;
        --line: #1e1e1b;
        --line-soft: #2c2c28;
        --accent: #d4c9a8;

        --font-sans: "Helvetica Neue", Helvetica, Arial, sans-serif;
        --mono: "SF Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, "Courier New", monospace;
        --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
        --gutter: 24px;

        /* Type scale (16px root). Modular-ish, hand-tuned per DESIGN-REFERENCE §1.
           Hero pushes wide (type-as-hero); body/label restrained. */
        --fs-hero: clamp(4rem, 9.6vw, 8rem);
        --fs-title: clamp(2rem, 6vw, 3rem);
        --fs-lede: 1.2rem;
        --fs-body: 1rem;
        --fs-label: 0.6875rem;
        --fs-meta: 0.75rem;
        --tracking-label: 0.16em;

        /* 8pt spacing scale (DESIGN-REFERENCE §2) */
        --sp-xs: 8px;
        --sp-s: 16px;
        --sp-m: 24px;
        --sp-l: 32px;
        --sp-xl: 48px;
        --sp-xxl: 80px;
      }

      :root[data-theme="light"] {
        --bg: #f4f2ed;
        --bg-0: #f4f2ed;
        --bg-1: #eceae4;
        --bg-2: #e2e0da;
        --fg: #0f0f0e;
        --fg-mid: #1e1e1c;
        --muted: #555550;
        --line: #a8a6a1;
        --line-soft: #dddbd5;
        --accent: #6b6358;
      }

      * {
        box-sizing: border-box;
      }

      html {
        -webkit-font-smoothing: antialiased; /* correct for dark default (BWT) */
        -moz-osx-font-smoothing: grayscale;
      }

      body {
        margin: 0;
        background: var(--bg-0);
        color: var(--fg);
        font-family: var(--font-sans);
        font-size: var(--fs-body);
        line-height: 1.5;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      a:hover,
      a:focus-visible {
        text-decoration: underline;
      }

      img {
        max-width: 100%;
        display: block;
      }

      .page {
        padding: 0 0 60px;
      }

      .container {
        width: 100%;
        margin: 0 auto;
      }

      .site-header {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 24px;
        align-items: center;
        border-bottom: 1px solid var(--line);
        padding: 18px var(--gutter);
      }

      .brand {
        font-size: var(--fs-body);
        font-weight: 400;
        line-height: 1;
      }

      .brand:hover {
        text-decoration: none;
        color: var(--muted);
      }

      .nav {
        display: flex;
        gap: 18px;
        align-items: center;
        font-size: var(--fs-body);
        line-height: 1;
        color: var(--muted);
      }

      .nav a {
        padding-bottom: 2px;
        border-bottom: 1px solid transparent;
      }

      .nav a:hover,
      .nav a:focus-visible {
        border-bottom-color: var(--fg);
        color: var(--fg);
        text-decoration: none;
      }

      .nav-icon {
        display: inline-flex;
        align-items: center;
        color: var(--muted);
      }

      .nav-icon:hover {
        color: var(--fg);
      }

      .nav-icon svg {
        width: 16px;
        height: 16px;
      }

      /* Diagonal split toggle — one half ink, one half page; inverts on flip. */
      .theme-toggle {
        width: 15px;
        height: 15px;
        padding: 0;
        border: 1px solid var(--fg);
        border-radius: 50%;
        background: linear-gradient(135deg, var(--fg) 0 50%, var(--bg) 50% 100%);
        cursor: pointer;
        display: inline-block;
        vertical-align: middle;
      }

      .theme-toggle:hover {
        border-color: var(--muted);
      }

      main {
        display: grid;
        gap: 40px;
        padding: 24px var(--gutter) 0;
      }

      footer {
        margin-top: 40px;
        border-top: 1px solid var(--line);
        padding: 14px var(--gutter) 0;
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        align-items: baseline;
        justify-content: space-between;
        font-size: var(--fs-label);
        text-transform: uppercase;
        letter-spacing: var(--tracking-label);
        color: var(--muted);
        font-family: var(--mono);
      }

      footer .email {
        text-transform: none;
        letter-spacing: 0.04em;
      }

      .colophon summary {
        cursor: pointer;
        list-style: none;
        opacity: 0.6;
        transition: opacity 0.15s;
      }

      .colophon summary:hover {
        opacity: 1;
      }

      .colophon summary::-webkit-details-marker {
        display: none;
      }

      .colophon-content {
        margin-top: 10px;
        display: grid;
        gap: 6px;
        text-transform: none;
        letter-spacing: 0.04em;
      }

      .colophon-content p {
        margin: 0;
        line-height: 1.5;
        color: var(--muted);
      }

      .eyebrow {
        font-family: var(--mono);
        font-size: var(--fs-label);
        text-transform: uppercase;
        letter-spacing: var(--tracking-label);
        color: var(--muted);
      }

      .section-title {
        font-size: var(--fs-title);
        line-height: 1.05;
        letter-spacing: -0.02em;
        margin: 10px 0 12px;
        font-weight: 300;
      }

      .section-lede {
        font-size: var(--fs-lede);
        color: var(--muted);
        max-width: 64ch;
      }

      .mono {
        font-family: var(--mono);
      }

      @media (min-width: 960px) {
        :root {
          --gutter: 48px;
        }
        .page {
          padding-bottom: 70px;
        }
      }

      @media (max-width: 720px) {
        footer {
          flex-direction: column;
          gap: 10px;
        }
      }

      /* DESIGN-REFERENCE §4 — the gap neither UI book covers. */
      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
          scroll-behavior: auto !important;
        }
      }
    </style>
  </head>
  <body>
    <div class="page">
      <div class="container">
        <header class="site-header">
          <a class="brand" href="/">timbeitz.com</a>
          <nav class="nav">
            <a href="/work">work</a>
            <a class="nav-icon" href="mailto:timbeitz@gmail.com" aria-label="Email Tim">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <rect x="3" y="5" width="18" height="14" rx="2" />
                <path d="M3 7l9 6 9-6" />
              </svg>
            </a>
            <button class="theme-toggle" type="button" data-theme-toggle aria-label="Switch theme"></button>
          </nav>
        </header>
        <main>
          <slot />
        </main>
        <footer>
          <a class="email" href="mailto:timbeitz@gmail.com">timbeitz@gmail.com</a>
          <details class="colophon">
            <summary>Colophon</summary>
            <div class="colophon-content">
              <p>Made in Philadelphia.</p>
              <p>Built with Astro and vanilla CSS, grounded in a corpus-defined type system.</p>
              <p>Set in Helvetica Neue &amp; SF Mono. Hosted on Vercel.</p>
            </div>
          </details>
        </footer>
      </div>
    </div>
    <script>
      const storageKey = "identity-surface-theme";
      const toggle = document.querySelector("[data-theme-toggle]");

      const applyTheme = (theme) => {
        document.documentElement.setAttribute("data-theme", theme);
      };

      // NU intent: dark by default; honor an explicit stored choice.
      const initTheme = () => {
        const stored = localStorage.getItem(storageKey);
        applyTheme(stored || "dark");
      };

      const updateToggle = (theme) => {
        if (!toggle) return;
        toggle.setAttribute("aria-label", theme === "dark" ? "Switch to light theme" : "Switch to dark theme");
      };

      initTheme();
      updateToggle(document.documentElement.getAttribute("data-theme") || "dark");

      if (toggle) {
        toggle.addEventListener("click", () => {
          const current = document.documentElement.getAttribute("data-theme") || "dark";
          const next = current === "dark" ? "light" : "dark";
          applyTheme(next);
          localStorage.setItem(storageKey, next);
          updateToggle(next);
        });
      }
    </script>
  </body>
</html>
