---
const {
  title = "timbeitz.com",
  description = "Tim Beitz — product, brand, and research work.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        color-scheme: light dark;
        --bg: #fcfcfb;
        --fg: #0f0f0f;
        --muted: #4f4f4f;
        --line: #d1d1d1;
        --accent: #0f0f0f;
        --gutter: 24px;
        --mono: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
          "Courier New", monospace;

        /* Type scale — intentionally small. Four roles, nothing else.
           body (reading) · lede (lead paragraphs) · label (uppercase nav/labels) · title (display) */
        --fs-body: 0.875rem;  /* 14px */
        --fs-lede: 1rem;      /* 16px */
        --fs-label: 0.6875rem;/* 11px */
        --fs-title: clamp(2.2rem, 5.5vw, 3.4rem);
        --tracking-label: 0.2em;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0c0c0c;
          --fg: #f2f2f2;
          --muted: #b6b6b6;
          --line: #2a2a2a;
          --accent: #f2f2f2;
        }
      }

      [data-theme="light"] {
        --bg: #fcfcfb;
        --fg: #0f0f0f;
        --muted: #4f4f4f;
        --line: #d1d1d1;
        --accent: #0f0f0f;
      }

      [data-theme="dark"] {
        --bg: #0c0c0c;
        --fg: #f2f2f2;
        --muted: #b6b6b6;
        --line: #2a2a2a;
        --accent: #f2f2f2;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--fg);
        font-family: "IBM Plex Sans", "Helvetica Neue", Helvetica, Arial, sans-serif;
        font-size: var(--fs-body);
        line-height: 1.6;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      a:hover,
      a:focus-visible {
        text-decoration: underline;
      }

      img {
        max-width: 100%;
        display: block;
      }

      .page {
        padding: 0 0 60px;
      }

      .container {
        max-width: none;
        width: 100%;
        margin: 0 auto;
      }

      .site-header {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 24px;
        align-items: center;
        border-bottom: 1px solid var(--line);
        padding: 18px var(--gutter);
      }

      .brand {
        font-size: var(--fs-body);
        font-weight: 400;
        line-height: 1;
      }

      .brand:hover {
        text-decoration: none;
        color: var(--muted);
      }

      .nav {
        display: flex;
        gap: 18px;
        align-items: center;
        font-size: var(--fs-body);
        line-height: 1;
        color: var(--muted);
      }

      .nav a {
        padding-bottom: 2px;
        border-bottom: 1px solid transparent;
      }

      .nav a:hover,
      .nav a:focus-visible {
        border-bottom-color: var(--fg);
        color: var(--fg);
        text-decoration: none;
      }

      .nav-icon {
        display: inline-flex;
        align-items: center;
        color: var(--muted);
      }

      .nav-icon:hover {
        color: var(--fg);
      }

      .nav-icon svg {
        width: 16px;
        height: 16px;
      }

      /* Theme toggle: a circle split diagonally — one half ink, one half page.
         Shows BOTH states at once; the halves invert when the theme flips
         (because --fg/--bg swap). */
      .theme-toggle {
        width: 15px;
        height: 15px;
        padding: 0;
        border: 1px solid var(--fg);
        border-radius: 50%;
        background: linear-gradient(135deg, var(--fg) 0 50%, var(--bg) 50% 100%);
        cursor: pointer;
        display: inline-block;
        vertical-align: middle;
      }

      .theme-toggle:hover {
        border-color: var(--muted);
      }

      main {
        display: grid;
        gap: 40px;
        padding: 24px var(--gutter) 0;
      }

      footer {
        margin-top: 40px;
        border-top: 1px solid var(--line);
        padding: 14px var(--gutter) 0;
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        align-items: baseline;
        justify-content: space-between;
        font-size: var(--fs-label);
        text-transform: uppercase;
        letter-spacing: var(--tracking-label);
        color: var(--muted);
      }

      footer .email {
        font-family: var(--mono);
        text-transform: none;
        letter-spacing: 0;
      }

      .colophon summary {
        cursor: pointer;
        list-style: none;
        opacity: 0.6;
        transition: opacity 0.15s;
      }

      .colophon summary:hover {
        opacity: 1;
      }

      .colophon summary::-webkit-details-marker {
        display: none;
      }

      .colophon-content {
        margin-top: 10px;
        display: grid;
        gap: 6px;
        text-transform: none;
        letter-spacing: 0;
        font-size: var(--fs-label);
      }

      .colophon-content p {
        margin: 0;
        line-height: 1.5;
        color: var(--muted);
      }

      /* Shared building blocks */
      .eyebrow {
        font-size: var(--fs-label);
        text-transform: uppercase;
        letter-spacing: var(--tracking-label);
        color: var(--muted);
      }

      .section-title {
        font-size: var(--fs-title);
        line-height: 1.05;
        letter-spacing: -0.01em;
        margin: 10px 0 12px;
        font-weight: 500;
      }

      .section-lede {
        font-size: var(--fs-lede);
        color: var(--muted);
        max-width: 64ch;
      }

      .mono {
        font-family: var(--mono);
      }

      @media (min-width: 960px) {
        :root {
          --gutter: 48px;
        }

        .page {
          padding-bottom: 70px;
        }
      }

      @media (max-width: 720px) {
        footer {
          flex-direction: column;
          gap: 10px;
        }
      }
    </style>
  </head>
  <body>
    <div class="page">
      <div class="container">
        <header class="site-header">
          <a class="brand" href="/">timbeitz.com</a>
          <nav class="nav">
            <a href="/work">work</a>
            <a class="nav-icon" href="mailto:timbeitz@gmail.com" aria-label="Email Tim">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <rect x="3" y="5" width="18" height="14" rx="2" />
                <path d="M3 7l9 6 9-6" />
              </svg>
            </a>
            <button class="theme-toggle" type="button" data-theme-toggle aria-label="Switch theme"></button>
          </nav>
        </header>
        <main>
          <slot />
        </main>
        <footer>
          <a class="email" href="mailto:timbeitz@gmail.com">timbeitz@gmail.com</a>
          <details class="colophon">
            <summary>Colophon</summary>
            <div class="colophon-content">
              <p>Made in Philadelphia.</p>
              <p>Built with Astro and vanilla CSS.</p>
              <p>AI-assisted by Claude via Claude Code. Hosted on Vercel. Set in IBM Plex.</p>
            </div>
          </details>
        </footer>
      </div>
    </div>
    <script>
      const storageKey = "identity-surface-theme";
      const toggle = document.querySelector("[data-theme-toggle]");

      const applyTheme = (theme) => {
        document.documentElement.setAttribute("data-theme", theme);
      };

      const systemTheme = () =>
        window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";

      const updateToggle = (theme) => {
        if (!toggle) return;
        // The circle shows the CURRENT color; the label announces the action.
        toggle.setAttribute("aria-label", theme === "dark" ? "Switch to light theme" : "Switch to dark theme");
      };

      const initTheme = () => {
        const stored = localStorage.getItem(storageKey);
        applyTheme(stored || systemTheme());
      };

      initTheme();
      updateToggle(document.documentElement.getAttribute("data-theme") || "light");

      if (toggle) {
        toggle.addEventListener("click", () => {
          const current = document.documentElement.getAttribute("data-theme") || "light";
          const next = current === "dark" ? "light" : "dark";
          applyTheme(next);
          localStorage.setItem(storageKey, next);
          updateToggle(next);
        });
      }
    </script>
  </body>
</html>
